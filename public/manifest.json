{
  "manifest_version": 3,
  "name": "SnapLayer",
  "version": "0.0.0",
  "description": "lets you overlay JPEG/PNG/SVG images on any webpage.",
  "permissions": ["activeTab", "scripting"],
  "web_accessible_resources": [
    {
      "resources": ["content.js"],
      "matches": ["http://*/*", "https://*/*"]
    }
  ],
  "icons": {
    "16": "favicon16.png",
    "32": "favicon32.png",
    "48": "favicon48.png",
    "128": "favicon128.png"
  },
  "action": {
    "default_title": "SnapLayer",
    "default_popup": "index.html"
  }
}
